# =============================================================================
# Claude Agent SDK Harness - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# =============================================================================
# Required Configuration
# =============================================================================
ANTHROPIC_API_KEY=your_api_key_here

# Optional Joplin Note-taking Application Key
# Use this (or Obsidian, or other) application as a conventient way and persist, read, and manually edit markdown files locally
JOPLIN_KEY=your_joplin_token_here